# Database
DATABASE_URL=postgresql://localhost/outbound

# ===== API Keys =====

# Apollo.io - Find executives (CISOs, CTOs, VPs)
# Get from: https://app.apollo.io/settings/integrations
APOLLO_API_KEY=

# EmailListChecker.io - Verify email addresses
# Get from: https://emaillistchecker.io/
EMAILLISTCHECKER_API_KEY=

# ===== Gmail OAuth =====
# Get from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/oauth/callback

# OAuth Refresh Token (generated by running: npm run inbox:auth-gmail)
GMAIL_REFRESH_TOKEN=

# ===== API Ingest (for your data source) =====
SOURCE_API_URL=https://your-api.com/companies
SOURCE_API_KEY=

# ===== Campaign Settings =====
CAMPAIGN_BATCH_SIZE=20
CAMPAIGN_RATE_LIMIT_PER_DAY=100
CAMPAIGN_TRACKING_DOMAIN=track.yourdomain.com

# Test mode recipient - all test emails go here
CAMPAIGN_TEST_RECIPIENT=your-email@example.com

# ===== Sender Accounts =====
# Generate encryption key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENDER_ENCRYPTION_KEY=

# ===== Inbox Server =====
INBOX_API_URL=http://localhost:3847

# ===== Optional =====
LOG_LEVEL=info
NODE_ENV=development

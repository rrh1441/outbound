# Gmail OAuth Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="GOCSPX-your-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Sender Information
GMAIL_FROM_EMAIL="your-email@gmail.com"
GMAIL_FROM_NAME="Your Name"

# OAuth Refresh Token (generated by running: npm run campaign:auth)
GMAIL_REFRESH_TOKEN=""

# Campaign Settings
CAMPAIGN_BATCH_SIZE=20
CAMPAIGN_RATE_LIMIT_PER_DAY=100
CAMPAIGN_TRACKING_DOMAIN="track.simplcyber.com"

# Optional: Tracking Server
TRACKING_SERVER_PORT=3001
TRACKING_SERVER_ENABLED=false
